{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
